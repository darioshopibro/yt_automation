      "title": "Worker Nodes",
      "direction": "right",
      "connectionToNext": "bidirectional",
      "sections": [
        {
          "title": "Three Processes",
          "layout": "flow",
          "nodes": [
            { "label": "Runtime", "icon": "Package" },
            { "label": "Kubelet", "icon": "Cpu" },
            { "label": "Kube-Proxy", "icon": "ShareNetwork" }
