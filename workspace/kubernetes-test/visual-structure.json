{
  "title": "Kubernetes Architecture Explained",
  "hierarchyType": "sticky",
  "stickies": [
    {
      "step": 1,
      "title": "Overview",
      "direction": "right",
      "connectionToNext": "flow",
      "sections": [
        {
          "title": "Master vs Worker",
          "visualType": "split-screen",
          "visualData": {
            "left": {
              "title": "Worker Nodes",
              "items": [
                "Run application containers",
                "Container runtime (Docker)",
                "Kubelet schedules pods",
                "Kube-proxy handles networking"
              ]
            },
            "right": {
              "title": "Master Nodes",
              "items": [
                "Control cluster state",
                "API Server (gateway)",
                "Scheduler assigns nodes",
                "Controller detects failures"
              ]
            },
            "leftColor": "#3b82f6",
            "rightColor": "#22c55e",
            "dividerLabel": "vs"
          }
        },
        {
          "title": "Cluster Setup",
          "visualType": "table",
          "visualData": {
            "headers": ["", "Master", "Worker"],
            "rows": [
