        },
        {
          "title": "Pod Lifecycle",
          "layout": "flow",
          "nodes": [
            { "label": "Config", "icon": "FileCode" },
            { "label": "Schedule", "icon": "Timer" },
            { "label": "Run Pod", "icon": "Play" },
            { "label": "Resources", "icon": "HardDrives" }
          ]
        },
        {
          "title": "Smart Routing",
          "layout": "flow",
          "nodes": [
            { "label": "Request", "icon": "ArrowRight" },
            { "label": "Service", "icon": "Funnel" },
            { "label": "Same Node", "icon": "CheckCircle" }
          ]
        }
      ]
    },
    {
      "step": 3,
      "title": "Master Nodes",
      "direction": "below",
      "connectionToNext": "flow",
      "sections": [
        {
          "title": "Control Plane",
          "layout": "flow",
          "nodes": [
            { "label": "API Server", "icon": "Globe" },
