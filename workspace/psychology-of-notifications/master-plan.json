        "endFrame": 1275,
        "componentPath": "src/visuals/Generated_SlotMachineComparison.tsx",
        "transcriptSegment": "If every notification were boring, you'd turn them off. If every one were exciting, you'd check eagerly but calmly. The randomness creates compulsion.",
